# ⚡ Electric Demand Forecasting - Configuration Template
# Copy this file to .env and set your own values

# ==========================================
# ENTSOE Data Ingestion
# ==========================================
# Required for running data pipeline and lazy model retraining
# Get your API key at: https://transparency.entsoe.eu/
# Free account required, approval takes 1-2 business days
ENTSOE_API_KEY=your_entsoe_transparency_platform_api_key_here

# ==========================================
# Google Cloud Storage (Optional)
# ==========================================
# If not set, models will be stored locally in /models/
# (Recommended for HF Spaces since local storage is not persistent)

# JSON credentials file for Google Cloud (full path or absolute)
# Can be generated with: gcloud auth application-default create
GCP_CREDENTIALS_JSON=/path/to/your/gcp-credentials.json

# GCS bucket name for model storage
# Example: gs://my-forecasting-models
MODEL_BUCKET_NAME=your-gcs-bucket-name

# ==========================================
# API Configuration (Optional)
# ==========================================
# These have sensible defaults in src/core/config.py
# Only override if you need different values for your deployment

# Maximum requests per minute (rate limiting)
# Default: 20 req/min
API_RATE_LIMIT_PER_MINUTE=20

# Weather data cache duration in minutes
# Default: 30 minutes (balances freshness vs API cost)
API_CACHE_TTL_MINUTES=30

# Maximum age of model before automatic retraining (days)
# Default: 7 days
MODEL_MAX_AGE_DAYS=7

# ==========================================
# Logging Configuration (Optional)
# ==========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# ==========================================
# HuggingFace Spaces Notes
# ==========================================
# If deploying to HF Spaces, add secrets via:
# Space Settings → Repository Secrets
#
# Required Secrets:
# - ENTSOE_API_KEY (for data pipeline)
#
# Optional Secrets:
# - GCP_CREDENTIALS_JSON (for GCS model storage)
# - MODEL_BUCKET_NAME (for GCS model storage)
#
# The .env file will be read from environment variables
# HF Spaces exposes them automatically during container startup
